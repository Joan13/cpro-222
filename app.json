{
  "expo": {
    "name": "yambi",
    "slug": "yambi",
    "version": "2.46.28",
    "scheme": "yambi",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yambi.app",
      "associatedDomains": [
        "applinks:app.yambi.net"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/ic_launcher_round.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.yambi.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.yambi.net",
              "pathPrefix": "/post"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.yambi.net",
              "pathPrefix": "/item"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.yambi.net",
              "pathPrefix": "/business"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./src/assets/logo1.png"
    },
    "plugins": [
      "./plugins/withReactNativeVectorIcons.js",
      [
        "expo-av",
        {
          "microphonePermission": "Yambi a besoin du microphone pour les messages vocaux et l’audio dans le chat."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-community/datetimepicker",
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.yambi",
          "enableGooglePay": true
        }
      ],
      "expo-sharing"
    ]
  }
}
